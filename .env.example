# OpenAI API Configuration for Local Development
# Get your API key from: https://platform.openai.com/account/api-keys
# 
# For local development:
# 1. Copy this file to .env.local
# 2. Add your actual API key below
# 3. The app will auto-load it on startup
#
# IMPORTANT: .env.local is in .gitignore and will never be committed to git
#
OPENAI_API_KEY=your_api_key_here

# Optional: Override model or settings during development
# OPENAI_MODEL=gpt-5.4-nano
# API_MAX_TOKENS=3000
